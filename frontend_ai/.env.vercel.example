# Vercel frontend environment template
# Set these in the Vercel project settings and mirror them locally if needed.

# Public Google OAuth client ID used by the React app.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend URL for production requests. The app appends /api/* paths to this base.
VITE_API_BASE_URL=https://your-render-service.onrender.com

# Optional public map search key used by the site selector.
VITE_GEOAPIFY_KEY=f2d9f28d68334fd4996fed8ae76fec0d

# Optional telemetry endpoint for the 3D scene.
VITE_TELEMETRY_ENDPOINT=
VITE_TELEMETRY_INTERVAL_MS=5000