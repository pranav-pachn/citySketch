# Render backend environment template
# Render injects PORT automatically, so leave PORT unset in production.

# Required persistence settings.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Google OAuth client ID used to verify frontend ID tokens.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Production CORS allowlist. Add your Vercel site and any preview URLs.
CORS_ALLOWLIST=https://your-frontend.vercel.app

# LLM provider keys. Keep only the providers you use.
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key

OPENROUTER_API_KEY=

GEMINI_API_KEY=



# Optional server-side telemetry guard.
TELEMETRY_SECRET=